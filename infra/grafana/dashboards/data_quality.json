{
  "uid": "dataone-data-quality",
  "title": "DataOne \u2014 Data Quality",
  "description": "Quarantine summary and pipeline health monitoring.",
  "tags": [
    "dataone",
    "quality"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Quarantined Rows",
      "type": "stat",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "dataone-clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "dataone-clickhouse"
          },
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT sum(row_count) FROM quarantine_summary",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Quarantine by Reason",
      "type": "barchart",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "dataone-clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 9,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "dataone-clickhouse"
          },
          "queryType": "sql",
          "format": 2,
          "rawSql": "SELECT failure_reason, sum(row_count) AS total FROM quarantine_summary GROUP BY failure_reason ORDER BY total DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Quarantine by Table",
      "type": "barchart",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "dataone-clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 9,
        "x": 15,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "dataone-clickhouse"
          },
          "queryType": "sql",
          "format": 2,
          "rawSql": "SELECT table_name, sum(row_count) AS total FROM quarantine_summary GROUP BY table_name ORDER BY total DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Daily Quarantine Trend",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "dataone-clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "dataone-clickhouse"
          },
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT batch_date AS time, table_name, sum(row_count) AS quarantined FROM quarantine_summary GROUP BY batch_date, table_name ORDER BY batch_date",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Quarantine Detailed Breakdown",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "dataone-clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "dataone-clickhouse"
          },
          "queryType": "sql",
          "format": 1,
          "rawSql": "SELECT batch_date, table_name, failure_reason, sum(row_count) AS rows FROM quarantine_summary GROUP BY batch_date, table_name, failure_reason ORDER BY batch_date DESC, rows DESC",
          "refId": "A"
        }
      ]
    }
  ]
}