# Copy this file to .env and adjust as needed. Never commit the real .env.
#
# Hostnames below (postgres, mongodb, kafka, nifi, clickhouse) are Docker
# Compose service names — correct for code running INSIDE a container (the
# Spark jobs in src/dataone/streaming/ and batch/). Code you run on your
# laptop directly (the generators via `make seed`, the CDC simulator) can't
# resolve those names — dataone/config.py auto-detects this (checks for
# /.dockerenv) and substitutes localhost automatically. You don't need a
# second .env for this; it Just Works given every port below is also
# published to the host in docker-compose.yml. Only override a host here if
# you're pointing at something that ISN'T the docker-compose service of the
# same name (e.g. a remote DB) — that disables the auto-translation for it.

# ---- Postgres (OLTP source + Iceberg JDBC catalog) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dataone
POSTGRES_USER=dataone
POSTGRES_PASSWORD=changeme

# ---- MongoDB (raw reviews) ----
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=dataone
MONGO_USER=dataone
MONGO_PASSWORD=changeme

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_ORDERS_CDC=orders-cdc
KAFKA_TOPIC_CLICKSTREAM=clickstream

# ---- ClickHouse ----
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=dataone_marts
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme

# ---- NiFi ----
NIFI_HOST=nifi
NIFI_PORT=8443
NIFI_USERNAME=admin
NIFI_PASSWORD=changeme1234
# Plain-HTTP port a ListenHTTP processor listens on for the reviews ingestion
# flow — separate from NIFI_PORT (8443, NiFi's own HTTPS UI/API).
# See docs/NIFI_FLOWS_GUIDE.md.
NIFI_REVIEWS_LISTEN_PORT=9900

# ---- Iceberg / Lakehouse ----
ICEBERG_WAREHOUSE_PATH=/data/lakehouse
ICEBERG_CATALOG_NAME=dataone_catalog

# ---- Spark ----
SPARK_MASTER_URL=spark://spark-master:7077

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme
TABIX_PORT=8088

# ---- Data Lineage ----
MARQUEZ_USER=marquez
MARQUEZ_PASSWORD=changeme

# ---- Synthetic data generators ----
GEN_ORDERS_TOTAL_ROWS=100000
GEN_PRODUCTS_TOTAL=2000
GEN_REVIEWS_TOTAL=5000
GEN_CLICKSTREAM_EVENTS_PER_SEC=200
GEN_SEED=42
GEN_MESSINESS_RATE=0.01
# "direct" writes straight to MongoDB (simple, no NiFi dependency).
# "nifi" POSTs each review to NiFi's ListenHTTP endpoint, which then lands it
# in MongoDB via PutMongo — exercises the actual ingestion architecture
# described in docs/NIFI_FLOWS_GUIDE.md.
GEN_REVIEWS_INGEST_MODE=nifi

# ---- Live orders generator (real-time simulation) ----
GEN_LIVE_ORDERS_PER_MINUTE=20
GEN_LIVE_UPDATE_BATCH_SIZE=10
GEN_LIVE_SEED=99
